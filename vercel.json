    { "source": "/api/admin/user/carga-peliculas", "destination": "/api/admin/user/peliculas" },
    { "source": "/api/admin/user/pelicula/buscar/:texto", "destination": "/api/admin/user/peliculas" },

    { "source": "/api/admin/user/pendientes", "destination": "/api/admin/user/pendientes" },
