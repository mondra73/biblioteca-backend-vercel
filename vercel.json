    { "source": "/api/admin/user/pendiente", "destination": "/api/admin/user/pendientes" },
    { "source": "/api/admin/user/carga-pendientes", "destination": "/api/admin/user/pendientes" },
    { "source": "/api/admin/user/pendiente/buscar/:texto", "destination": "/api/admin/user/pendientes" },

    { "source": "/api/admin", "destination": "/api/admin/index" }
  ]
