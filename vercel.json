{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth/[...path]" },

    { "source": "/api/admin/estadisticas", "destination": "/api/admin/estadisticas" },
    { "source": "/api/admin/estadisticas-libros", "destination": "/api/admin/estadisticas" },
    { "source": "/api/admin/estadisticas-peliculas", "destination": "/api/admin/estadisticas" },
