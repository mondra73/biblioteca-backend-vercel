    { "source": "/api/admin/user/serie/:id", "destination": "/api/admin/user/series" },
    { "source": "/api/admin/user/serie", "destination": "/api/admin/user/series" },
    { "source": "/api/admin/user/carga-series", "destination": "/api/admin/user/series" },
    { "source": "/api/admin/user/serie/buscar/:texto", "destination": "/api/admin/user/series" },

